<html lang="en">
	<head>
		<meta charset="utf-8" />	
		<title>меньше 14кб</title>
<style>
	body{background: #ffffff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        margin: 0;}
	.page {display: none; align-items: center;}
	.page.active {display: flex;}
	button {cursor: pointer;height: 70%;}
	.line{height: 100%;  width: 1px;background: #000000;margin: 0 8px;}
	h1{margin: 0;height: 70%; padding: 15px 20px; }
	h2{ }
	.border{border-radius: 10px;border-color: black;border-style: solid;  
		margin: 0 auto;text-align: center;color: #ffffff;font-size:
		 24px;font-weight: bold;line-height: 1.5;letter-spacing: 1px 
		 ;padding:0 10px; background: #b80101; }
</style>
	</head>
	<body>
		<div><img src="cat3.webp" width="100" height="100" alt="cat"></div>
		<div id="p1" class="page active border">
			<h1>первая страница</h1>
			<div class="line"></div>
			<button onclick="showPage('p2')">На вторую</button>
		</div>
		<div id="p2" class="page border">
			<h1>вторая страница</h1> 
			<div class="line"></div>			
			<button onclick="showPage('p1')">На первую</button>
		</div>
		<script is:inline>
			function showPage(pageId, push=true) {
				document.querySelectorAll('.page').forEach((el) => el.classList.remove('active'));
				const target = document.getElementById(pageId);
				if (target) target.classList.add('active');
				if (push) history.pushState({pageId}, '', `#${pageId}`);
			}
				window.onpopstate = (event) => {
					if (event.state && event.state.pageId) {
					showPage(event.state.pageId, false);
				}				else {showPage('p1', false);}
			};
				window.addEventListener('DOMContentLoaded', () => {
					const hash = window.location.hash.slice(1);
					 if (hash) showPage(hash, false);});
				
		</script>
	</body>
</html>
